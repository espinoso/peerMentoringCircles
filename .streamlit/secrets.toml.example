# Copy this file to `.streamlit/secrets.toml` (locally) or paste its contents
# into the Streamlit Community Cloud "Secrets" box (when deployed).
# Do NOT commit the real secrets.toml.

# The single access word users must type to open the app.
# Leave blank/remove to disable the login (e.g. for local testing).
APP_PASSWORD = "change-me"

# API key for the provider selected in config.toml.
# Only the one you use is required.
OPENAI_API_KEY = "sk-..."
# ANTHROPIC_API_KEY = "sk-ant-..."
